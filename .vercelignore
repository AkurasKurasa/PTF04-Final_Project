# Caches
__pycache__/
**/__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# Virtualenvs
.venv/
venv/

# Frontend deps (none, but be safe)
node_modules/

# Source notebooks + raw datasets — frontend uses pre-rendered HTML in pages/
notebooks/
datasets/

# Generated executed snapshots
pages/*.executed.ipynb

# Local-only training + conversion scripts
rebuild_*.py
backend/train_*.py
backend/convert_models_to_onnx.py

# Local-only requirements (TF + jupyter stack); cloud uses api/requirements.txt
requirements-local.txt
backend/requirements-local.txt

# Heavy training artefacts — replaced by .onnx for cloud inference
models/*.keras
models/*.h5
models/*.onnx.data
models/*.tflite

# OS / IDE noise
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.log
