{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "backend/app.py": {
      "runtime": "@vercel/python@4.3.0",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/app.py" }
  ],
  "cleanUrls": true
}
