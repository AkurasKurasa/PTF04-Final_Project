{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ],
  "cleanUrls": true,
  "build": {
    "env": {
      "PYTHONDONTWRITEBYTECODE": "1"
    }
  },
  "functions": {
    "api/*.py": {
      "memory": 1024,
      "maxDuration": 60,
      "excludeFiles": "{notebooks,datasets,pages,.git,.vercel,node_modules,.venv,venv}/**,models/*.{keras,h5},**/__pycache__/**,**/*.pyc"
    }
  }
}
